dataset_path: json
test_split: test
output_type: generate_until

doc_to_visual: !function utils.cholec80_doc_to_visual
doc_to_text: !function utils.cholec80_doc_to_text
doc_to_target: !function utils.cholec80_doc_to_target
process_results: !function utils.cholec80_process_results

metric_list:
  - metric: cholec80_accuracy
    aggregation: !function utils.cholec80_aggregate_accuracy
    higher_is_better: true
  - metric: cholec80_answered_rate
    aggregation: !function utils.cholec80_aggregate_answered_rate
    higher_is_better: true

generation_kwargs:
  max_new_tokens: 64
  temperature: 0
  do_sample: false

lmms_eval_specific_kwargs:
  default:
    pre_prompt: ""
    post_prompt: ""

metadata:
  version: 0.0
